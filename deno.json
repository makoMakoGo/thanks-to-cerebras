{
  "unstable": ["kv"],
  "fmt": {
    "exclude": ["src/ui/admin.html"]
  },
  "deploy": {
    "org": "lovingfish",
    "app": "thanks-to-cerebras",
    "runtime": {
      "type": "dynamic",
      "entrypoint": "main.ts"
    }
  },
  "tasks": {
    "dev": "deno run --allow-net --allow-env --allow-read --allow-write main.ts",
    "start": "deno run --allow-net --allow-env --allow-read --allow-write main.ts",
    "test": "deno test --allow-net --allow-env --allow-read --allow-write",
    "test:unit": "deno test --allow-net --allow-env --allow-read --allow-write src/__tests__/",
    "test:junit": "mkdir -p reports && deno test --allow-net --allow-env --allow-read --allow-write --reporter=dot --junit-path=reports/junit.xml src/__tests__/",
    "test:ci": "mkdir -p reports && deno test --allow-net --allow-env --allow-read --allow-write --clean --coverage=coverage --coverage-raw-data-only --reporter=dot --junit-path=reports/junit.xml src/__tests__/",
    "test:coverage": "deno test --allow-net --allow-env --allow-read --allow-write --clean --coverage=coverage --coverage-raw-data-only src/__tests__/",
    "test:flaky": "deno run --allow-run=deno --allow-env --allow-read --allow-write --allow-net scripts/flaky-test-check.ts --runs 2",
    "coverage:lcov": "deno coverage --lcov --output=coverage/coverage.lcov --include='^file:.*/(main|src)/' --exclude='(_test|test-utils)\\.ts$|/src/ui/admin\\.html$' coverage",
    "coverage:check": "deno run --allow-read scripts/coverage-threshold.ts coverage/coverage.lcov --line-threshold 75",
    "test:performance": "deno run --allow-read scripts/test-performance-report.ts reports/junit.xml --slow-threshold 8",
    "check": "deno check main.ts src scripts/*.ts",
    "lint": "deno lint --rules-include=camelcase main.ts src scripts/*.ts",
    "naming:check": "deno run --allow-read scripts/naming-check.ts",
    "complexity:check": "deno run --allow-read scripts/complexity-check.ts --max 22",
    "module-boundaries:check": "deno run --allow-read scripts/module-boundaries-check.ts",
    "agents:check": "deno run --allow-read scripts/agents-check.ts",
    "large-files:check": "deno run --allow-read scripts/large-file-check.ts",
    "tech-debt:check": "deno run --allow-read scripts/tech-debt-check.ts",
    "duplicate-code:check": "deno run --allow-read scripts/duplicate-code-check.ts --min-lines 12",
    "unused-deps:check": "deno run --allow-read scripts/unused-deps-check.ts",
    "openapi:check": "deno run --allow-read scripts/validate-openapi.ts",
    "dast:check": "deno run --allow-net --allow-env scripts/dast-check.ts",
    "fmt:check": "deno fmt --check main.ts src scripts/*.ts",
    "hooks:install": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit .githooks/post-push",
    "docstring:coverage": "deno run --allow-read scripts/docstring-coverage.mjs --threshold 80"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.18"
  }
}
